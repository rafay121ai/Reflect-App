# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Security
ALLOWED_ORIGINS=https://your-app.vercel.app

# RevenueCat (server-side: reflection rate limiting by subscription tier)
# Optional: if not set, all users are treated as trial. Use Secret API key from Project Settings > API Keys.
# REVENUECAT_SECRET_API_KEY=sk_...

# Lemon Squeezy (web subscriptions: webhook + variant mapping)
# Webhook secret from Lemon Squeezy Dashboard > Settings > Webhooks. Used to verify webhook signatures.
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# Optional API key for server-side API calls (e.g. subscription lookup).
# LEMON_SQUEEZY_API_KEY=
# Variant IDs for monthly and yearly plans (from your Lemon Squeezy product variants).
# LS_VARIANT_MONTHLY=
# LS_VARIANT_YEARLY=
