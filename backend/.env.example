# ── SECURITY ─────────────────────────────────────────────────────
# ENV: set to 'production' on Railway, 'development' locally
ENV=development

# ALLOWED_ORIGINS: comma-separated frontend URLs (no trailing slash)
# Production example:
# https://reflect-app-two.vercel.app,https://reflect-web-one.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ALLOWED_HOSTS: comma-separated backend hostnames (no protocol)
# Production example:
# your-app.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1
# ─────────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4.1-mini

# RevenueCat (server-side: reflection rate limiting by subscription tier)
# Optional: if not set, all users are treated as trial. Use Secret API key from Project Settings > API Keys.
# REVENUECAT_SECRET_API_KEY=sk_...

# Lemon Squeezy (web subscriptions: webhook + variant mapping)
# Webhook secret from Lemon Squeezy Dashboard > Settings > Webhooks. Used to verify webhook signatures.
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# Optional API key for server-side API calls (e.g. subscription lookup).
# LEMON_SQUEEZY_API_KEY=
# Variant IDs for monthly and yearly plans (from your Lemon Squeezy product variants).
# LS_VARIANT_MONTHLY=
# LS_VARIANT_YEARLY=
